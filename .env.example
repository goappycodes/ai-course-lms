# Copy this file to .env and fill in what you have.
# Every player falls back to a public demo video until its variables are set,
# so the app works out of the box.

# ------------------------------------------------------------------
# 1) Cloudflare Stream  (managed encoding + delivery + player)
# ------------------------------------------------------------------
# Account ID: Cloudflare dashboard -> right sidebar on any zone, or dash.cloudflare.com -> Workers & Pages
CF_ACCOUNT_ID=
# API token with "Stream:Edit" permission (My Profile -> API Tokens -> Create Token)
CF_STREAM_API_TOKEN=
# The customer code from your Stream subdomain: customer-XXXX.cloudflarestream.com
# (shown in the Stream dashboard, and printed by scripts/upload-stream.mjs after upload)
CF_STREAM_CUSTOMER_CODE=
# Video UID, printed by scripts/upload-stream.mjs (or copy from the Stream dashboard)
CF_STREAM_VIDEO_UID=

# ------------------------------------------------------------------
# 2) MUX  (managed encoding + delivery + player)
# ------------------------------------------------------------------
# Settings -> Access Tokens -> Generate new token (environment: your env, permission: Mux Video read+write)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Playback ID, printed by scripts/upload-mux.mjs (or copy from the MUX dashboard asset page)
MUX_PLAYBACK_ID=

# ------------------------------------------------------------------
# 3) AWS S3 + CloudFront  (storage + CDN, you bring the file)
# ------------------------------------------------------------------
# IAM user with s3:PutObject/GetObject on the bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=
# CloudFront distribution domain pointing at the bucket, e.g. https://d1234abcd.cloudfront.net
CLOUDFRONT_URL=
# Object key of the video to play, e.g. videos/lesson1.mp4  (or hls/lesson1/master.m3u8 if you upload HLS)
S3_VIDEO_KEY=

# ------------------------------------------------------------------
# 4) Cloudflare R2 + self-managed HLS  (zero egress; you encode with ffmpeg)
# ------------------------------------------------------------------
# Usually the same account as CF_ACCOUNT_ID
R2_ACCOUNT_ID=
# R2 -> Manage R2 API Tokens -> Create API token (Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL of the bucket: either the r2.dev public URL (enable in bucket settings -> Public access)
# or a custom domain connected to the bucket, e.g. https://pub-xxxxxxxx.r2.dev or https://videos.yourdomain.com
R2_PUBLIC_URL=
# Prefix where scripts/upload-r2.mjs uploaded the HLS folder, e.g. hls/lesson1 (expects master.m3u8 inside)
R2_VIDEO_PREFIX=

# ------------------------------------------------------------------
# 5) YouTube (benchmark only — no credentials needed)
# ------------------------------------------------------------------
# Upload your sample lesson as "unlisted" on YouTube and paste the video ID
# (the part after v= in the URL). Falls back to a public demo video.
YOUTUBE_VIDEO_ID=
